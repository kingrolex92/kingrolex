APP_ENV=production
APP_NAME=TravelSaaS
APP_URL=http://localhost
PUBLIC_URL=http://localhost

# Service ports
API_PORT=8080
WEB_PORT=3000
BOT_PORT=8081

# Database
POSTGRES_USER=travel
POSTGRES_PASSWORD=change-me
POSTGRES_DB=travel
DATABASE_URL=postgres://travel:${POSTGRES_PASSWORD}@postgres:5432/travel?sslmode=disable

# Cache
REDIS_URL=redis://redis:6379/0

# Auth
JWT_SECRET=change-me-please

# WhatsApp Cloud API
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_APP_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_URL=http://localhost/webhook/whatsapp

# Payments (Stripe example)
PAYMENT_PROVIDER=stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Object storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# Security
CORS_ORIGINS=*
HEALTHCHECK_SECRET=change-me-health